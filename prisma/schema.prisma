generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  noReg     String   @unique
  name      String
  email     String   @unique
  noHp      String
  role      Role     @default(MEMBER)
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events      Event[]    @relation("EventPIC")
  projects    Project[]  @relation("ProjectPIC")
  tasks       Task[]     @relation("TaskPIC")
  regularJobs RegularJob[] @relation("RegularJobPIC")
  notifications Notification[]

  @@map("users")
}

enum Role {
  MEMBER
  LEADER
  SPV
  DPH
}

model Event {
  id        Int      @id @default(autoincrement())
  name      String
  picId     Int
  pic       User     @relation("EventPIC", fields: [picId], references: [id])
  progress  Float    @default(0)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasks Task[] @relation("EventTasks")

  @@map("events")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  picId     Int
  pic       User     @relation("ProjectPIC", fields: [picId], references: [id])
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasks Task[] @relation("ProjectTasks")

  @@map("projects")
}

model Task {
  id         Int          @id @default(autoincrement())
  name       String
  picId      Int
  pic        User         @relation("TaskPIC", fields: [picId], references: [id])
  progress   Float        @default(0)
  sourceType SourceType
  status     TaskStatus   @default(TODO)
  priority   TaskPriority @default(LOW)
  
  // Timing fields
  date       String?      // Format: YYYY-MM-DD
  startTime  String?      // Format: HH:mm
  endTime    String?      // Format: HH:mm
  dueDate    DateTime?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Source Relations (Optional)
  eventId      Int?
  event        Event?      @relation("EventTasks", fields: [eventId], references: [id], onDelete: Cascade)
  projectId    Int?
  project      Project?    @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  regularJobId Int?
  regularJob   RegularJob? @relation("RegularJobTasks", fields: [regularJobId], references: [id], onDelete: Cascade)

  // Relations
  activities Activity[]

  @@map("tasks")
}

enum SourceType {
  EVENT
  PROJECT
  PERSONAL
  REGULAR
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum RegularCategory {
  SAFETY
  QUALITY
  MAINTENANCE
  FIVE_S
  ENVIRONMENT
}

enum RegularFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model Activity {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("activities")
}

model RegularJob {
  id        Int              @id @default(autoincrement())
  name      String
  picId     Int
  pic       User             @relation("RegularJobPIC", fields: [picId], references: [id])
  category  RegularCategory  @default(SAFETY)
  frequency RegularFrequency @default(DAILY)
  progress  Float            @default(0)
  startTime String?          // Format: HH:mm
  endTime   String?          // Format: HH:mm
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  tasks Task[] @relation("RegularJobTasks")

  @@map("regular_jobs")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  type      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

